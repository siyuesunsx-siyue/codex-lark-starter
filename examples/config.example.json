{
  "_comment": "codex-lark-starter configuration. Copy to config.json and fill in your values.",
  "lark": {
    "platform": "feishu",
    "appId": "cli_xxxxxxxxxxxxxxxx",
    "appSecret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
